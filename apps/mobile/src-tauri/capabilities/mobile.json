{
  "$schema": "../gen/schemas/capability.json",
  "identifier": "mobile-capability",
  "description": "Permissions for the mobile application",
  "windows": ["main"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "shell:default",
    "notification:default",
    "log:default",
    "store:default"
  ]
}
