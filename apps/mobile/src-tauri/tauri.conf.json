{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "boilerplate",
  "version": "0.1.0",
  "identifier": "com.laboratorio3030.boilerplate",
  "build": {
    "devUrl": "http://localhost:4321",
    "beforeDevCommand": "cd ../../web && pnpm dev",
    "beforeBuildCommand": "cd ../../web && pnpm build",
    "frontendDist": "../../../apps/web/dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self' http://localhost:8080"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../../desktop/icons/32x32.png",
      "../../desktop/icons/128x128.png",
      "../../desktop/icons/128x128@2x.png",
      "../../desktop/icons/icon.icns",
      "../../desktop/icons/icon.ico"
    ]
  }
}
