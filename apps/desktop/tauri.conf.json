{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "boilerplate",
  "version": "0.1.0",
  "identifier": "com.laboratorio3030.boilerplate",
  "build": {
    "devUrl": "http://localhost:4321",
    "beforeDevCommand": "pnpm --filter apps-web dev",
    "beforeBuildCommand": "pnpm --filter apps-web build",
    "frontendDist": "../../apps/web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Boilerplate",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:8080"
    },
    "trayIcon": {
      "iconPath": "icons/32x32.png"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
