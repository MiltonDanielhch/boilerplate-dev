{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "boilerplate",
  "version": "0.1.0",
  "identifier": "com.laboratorio3030.boilerplate",
  "build": {
    "devUrl": "http://localhost:4321",
    "beforeDevCommand": "cd ../apps/web && pnpm dev"
  },
  "app": {
    "windows": [
      {
        "title": "Boilerplate",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:4321 http://localhost:3000"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"]
  }
}
