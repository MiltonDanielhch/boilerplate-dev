---
// Ubicación: `apps/web/src/pages/dashboard/roles.astro`
//
// Descripción: Página de gestión de roles y permisos.
//              Permite admin/gestión de roles.
//
// ADRs relacionados: 0022 (Frontend), 0006 (RBAC)

import DashboardLayout from "../../layouts/DashboardLayout.astro";
import * as Card from "$lib/components/ui/card/index.js";
import { Button } from "$lib/components/ui/button/index.js";
import * as m from "$lib/paraglide/messages.js";
---

<DashboardLayout title={`${m.roles_title()} - Dashboard`}>
	<div class="space-y-6">
		<div>
			<h1 class="text-3xl font-bold tracking-tight">{m.roles_title()}</h1>
			<p class="text-muted-foreground mt-2">
				{m.roles_description()}
			</p>
		</div>

		<!-- Admin Role -->
		<Card.Root>
			<Card.Header>
				<Card.Title>{m.role_admin()}</Card.Title>
				<Card.Description>
					{m.roles_admin_desc()}
				</Card.Description>
			</Card.Header>
			<Card.Content>
				<div class="space-y-2">
					<p class="text-sm"><span class="font-medium">{m.label_permissions()}:</span> {m.permissions_all()}</p>
				</div>
			</Card.Content>
		</Card.Root>

		<!-- Moderator Role -->
		<Card.Root>
			<Card.Header>
				<Card.Title>{m.role_moderator()}</Card.Title>
				<Card.Description>
					{m.roles_moderator_desc()}
				</Card.Description>
			</Card.Header>
		</Card.Root>

		<!-- User Role -->
		<Card.Root>
			<Card.Header>
				<Card.Title>{m.role_user()}</Card.Title>
				<Card.Description>
					{m.roles_user_desc()}
				</Card.Description>
			</Card.Header>
		</Card.Root>
	</div>
</DashboardLayout>