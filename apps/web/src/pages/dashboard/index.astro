---
// Ubicación: `apps/web/src/pages/dashboard/index.astro`
//
// Descripción: Dashboard unificado con métricas para todos los usuarios.
//              Secciones de admin solo visibles con permiso admin:read.
//
// ADRs relacionados: 0022 (Frontend), 0006 (RBAC)

import DashboardLayout from "../../layouts/DashboardLayout.astro";
import StatsOverview from "../../components/dashboard/StatsOverview.svelte";
import EventFeed from "../../components/dashboard/EventFeed.svelte";
import SystemHealth from "../../components/dashboard/SystemHealth.svelte";
import { PermissionGate } from "$lib/components/ui/permission-gate";
import * as Card from "$lib/components/ui/card/index.js";
import { Button } from "$lib/components/ui/button/index.js";
import { Plus, Users, ClipboardList, Settings, Shield } from "lucide-svelte";
---

<DashboardLayout title="Dashboard">
	<div class="space-y-8">
		<!-- Header -->
		<div class="flex items-center justify-between">
			<div>
				<h1 class="text-3xl font-bold tracking-tight">Dashboard</h1>
				<p class="text-muted-foreground mt-2">
					Overview of your system and recent activity
				</p>
			</div>
			<div class="flex gap-2">
				<PermissionGate permission="users:write" client:load>
					<Button client:load>
						<Plus class="h-4 w-4 mr-2" />
						Add User
					</Button>
				</PermissionGate>
			</div>
		</div>

		<!-- Stats Overview (para todos) -->
		<StatsOverview client:load />

		<!-- Grid de contenido (para todos) -->
		<div class="grid gap-6 lg:grid-cols-2">
			<!-- Event Feed -->
			<Card.Root>
				<Card.Header>
					<Card.Title class="flex items-center gap-2">
						<ClipboardList class="h-5 w-5" />
						Recent Activity
					</Card.Title>
					<Card.Description>
						Latest actions and events from the system
					</Card.Description>
				</Card.Header>
				<Card.Content>
					<EventFeed client:load />
				</Card.Content>
			</Card.Root>

			<!-- System Health -->
			<Card.Root>
				<Card.Header>
					<Card.Title class="flex items-center gap-2">
						<Settings class="h-5 w-5" />
						System Health
					</Card.Title>
					<Card.Description>
						API, Database, and Services status
					</Card.Description>
				</Card.Header>
				<Card.Content>
					<SystemHealth client:load />
				</Card.Content>
			</Card.Root>
		</div>

		<!-- Quick Actions (para todos) -->
		<Card.Root>
			<Card.Header>
				<Card.Title>Quick Actions</Card.Title>
				<Card.Description>
					Common tasks and shortcuts
				</Card.Description>
			</Card.Header>
			<Card.Content>
				<div class="flex flex-wrap gap-3">
					<PermissionGate permission="users:read" client:load>
						<Button variant="outline" href="/dashboard/users" client:load>
							<Users class="h-4 w-4 mr-2" />
							Manage Users
						</Button>
					</PermissionGate>
					<PermissionGate permission="audit:read" client:load>
						<Button variant="outline" href="/dashboard/audit" client:load>
							<ClipboardList class="h-4 w-4 mr-2" />
							View Audit Logs
						</Button>
					</PermissionGate>
					<Button variant="outline" href="/dashboard/roles" client:load>
						<Shield class="h-4 w-4 mr-2" />
						Roles
					</Button>
					<Button variant="outline" href="/dashboard/settings" client:load>
						<Settings class="h-4 w-4 mr-2" />
						Settings
					</Button>
				</div>
			</Card.Content>
		</Card.Root>
	</div>
</DashboardLayout>