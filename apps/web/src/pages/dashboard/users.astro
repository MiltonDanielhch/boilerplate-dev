---
// Ubicación: `apps/web/src/pages/dashboard/users.astro`
//
// Descripción: Página de gestión de usuarios con tabla paginada.
//              Requiere permiso users:read en el servidor (ADR 0006).
//
// ADRs relacionados: 0022 (Frontend), 0006 (RBAC), 0006 (Soft Delete)

import DashboardLayout from "../../layouts/DashboardLayout.astro";
import UserTable from "../../components/users/UserTable.svelte";

// TODO: Verificar permiso users:read en SSR
// Si no tiene permiso, redirigir a 403 o mostrar mensaje
---

<DashboardLayout title="Users - Dashboard">
	<div class="space-y-6">
		<div>
			<h1 class="text-3xl font-bold tracking-tight">Users</h1>
			<p class="text-muted-foreground mt-2">
				Manage user accounts, roles, and permissions
			</p>
		</div>

		<UserTable
			client:load
			canDelete={true}
			canRestore={true}
		/>
	</div>
</DashboardLayout>
