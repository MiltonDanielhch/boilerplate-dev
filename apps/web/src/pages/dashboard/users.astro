---
// Ubicación: `apps/web/src/pages/dashboard/users.astro`
//
// Descripción: Página de gestión de usuarios con tabla paginada.
//              Requiere permiso users:read en el servidor (ADR 0006).
//
// ADRs relacionados: 0022 (Frontend), 0006 (RBAC), 0006 (Soft Delete), 0023 (i18n)

import DashboardLayout from "../../layouts/DashboardLayout.astro";
import UserTable from "../../components/users/UserTable.svelte";
import CreateUserButton from "../../components/users/CreateUserButton.svelte";
import { PermissionGate } from "$lib/components/ui/permission-gate";
import * as m from "$lib/paraglide/messages.js";

// TODO: Verificar permiso users:read en SSR
// Si no tiene permiso, redirigir a 403 o mostrar mensaje
---

<DashboardLayout title={`${m.users_title()} - Dashboard`}>
	<div class="space-y-6">
		<!-- Header con botón Crear Usuario -->
		<div class="flex items-center justify-between">
			<div>
				<h1 class="text-3xl font-bold tracking-tight">{m.users_title()}</h1>
				<p class="text-muted-foreground mt-2">
					{m.users_description_full()}
				</p>
			</div>
			<PermissionGate permission="users:write" client:load>
				<CreateUserButton client:load />
			</PermissionGate>
		</div>

		<UserTable client:load />
	</div>
</DashboardLayout>
