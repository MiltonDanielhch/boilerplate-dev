---
// Ubicación: `apps/web/src/pages/dashboard/audit.astro`
//
// Descripción: Página de logs de auditoría con lista de eventos del sistema.
//              Requiere permiso audit:read - redirige si no tiene permiso.
//
// ADRs relacionados: 0022 (Frontend), 0006 (RBAC)

import DashboardLayout from "../../layouts/DashboardLayout.astro";
import * as Card from "$lib/components/ui/card/index.js";
import { Button } from "$lib/components/ui/button/index.js";
import { ClipboardList, Download, Filter } from "lucide-svelte";

// TODO: Implementar verificación SSR de permiso audit:read
// const hasAuditRead = Astro.locals.user?.permissions?.includes('audit:read');
// if (!hasAuditRead) {
//   return Astro.redirect('/dashboard?error=unauthorized');
// }
---

<DashboardLayout title="Audit Logs">
	<div class="space-y-6">
		<!-- Header -->
		<div class="flex items-center justify-between">
			<div>
				<h1 class="text-3xl font-bold tracking-tight">Audit Logs</h1>
				<p class="text-muted-foreground mt-2">
					System events and user activity tracking
				</p>
			</div>
			<div class="flex gap-2">
				<Button variant="outline" client:load>
					<Filter class="h-4 w-4 mr-2" />
					Filter
				</Button>
				<Button variant="outline" client:load>
					<Download class="h-4 w-4 mr-2" />
					Export
				</Button>
			</div>
		</div>

		<!-- Audit Log Table -->
		<Card.Root>
			<Card.Header>
				<Card.Title class="flex items-center gap-2">
					<ClipboardList class="h-5 w-5" />
					System Events
				</Card.Title>
				<Card.Description>
					Recent audit events from the system
				</Card.Description>
			</Card.Header>
			<Card.Content>
				<!-- TODO: Implementar AuditLogTable component -->
				<div class="py-8 text-center text-muted-foreground">
					<p>Audit log table will be implemented in the next phase.</p>
					<p class="text-sm mt-2">This will show events like user logins, data changes, etc.</p>
				</div>
			</Card.Content>
		</Card.Root>

		<!-- Info Card -->
		<Card.Root>
			<Card.Header>
				<Card.Title>About Audit Logs</Card.Title>
				</Card.Header>
			<Card.Content>
				<p class="text-sm text-muted-foreground">
					Audit logs track all significant events in the system including user authentication,
					data modifications, and administrative actions. Logs are retained according to
					the organization's data retention policy.
				</p>
			</Card.Content>
		</Card.Root>
	</div>
</DashboardLayout>
