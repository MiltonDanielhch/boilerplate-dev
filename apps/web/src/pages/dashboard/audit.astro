---
// Ubicación: `apps/web/src/pages/dashboard/audit.astro`
//
// Descripción: Página de logs de auditoría con lista de eventos del sistema.
//              Requiere permiso audit:read - redirige si no tiene permiso.
//
// ADRs relacionados: 0022 (Frontend), 0006 (RBAC), 0023 (i18n)

import DashboardLayout from "../../layouts/DashboardLayout.astro";
import * as Card from "$lib/components/ui/card/index.js";
import { Button } from "$lib/components/ui/button/index.js";
import { ClipboardList, Download, Filter } from "lucide-svelte";
import * as m from "$lib/paraglide/messages.js";

// TODO: Implementar verificación SSR de permiso audit:read
// const hasAuditRead = Astro.locals.user?.permissions?.includes('audit:read');
// if (!hasAuditRead) {
//   return Astro.redirect('/dashboard?error=unauthorized');
// }
---

<DashboardLayout title={m.audit_title_full()}>
	<div class="space-y-6">
		<!-- Header -->
		<div class="flex items-center justify-between">
			<div>
				<h1 class="text-3xl font-bold tracking-tight">{m.audit_title_full()}</h1>
				<p class="text-muted-foreground mt-2">
					{m.audit_description()}
				</p>
			</div>
			<div class="flex gap-2">
				<Button variant="outline" client:load>
					<Filter class="h-4 w-4 mr-2" />
					{m.action_filter()}
				</Button>
				<Button variant="outline" client:load>
					<Download class="h-4 w-4 mr-2" />
					{m.action_export()}
				</Button>
			</div>
		</div>

		<!-- Audit Log Table -->
		<Card.Root>
			<Card.Header>
				<Card.Title class="flex items-center gap-2">
					<ClipboardList class="h-5 w-5" />
					{m.audit_system_events()}
				</Card.Title>
				<Card.Description>
					{m.audit_recent_events()}
				</Card.Description>
			</Card.Header>
			<Card.Content>
				<!-- TODO: Implementar AuditLogTable component -->
				<div class="py-8 text-center text-muted-foreground">
					<p>{m.audit_table_placeholder()}</p>
					<p class="text-sm mt-2">{m.audit_table_subtitle()}</p>
				</div>
			</Card.Content>
		</Card.Root>

		<!-- Info Card -->
		<Card.Root>
			<Card.Header>
				<Card.Title>{m.audit_about()}</Card.Title>
				</Card.Header>
			<Card.Content>
				<p class="text-sm text-muted-foreground">
					{m.audit_about_description()}
				</p>
			</Card.Content>
		</Card.Root>
	</div>
</DashboardLayout>
