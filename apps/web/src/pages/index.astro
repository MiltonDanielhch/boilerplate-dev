---
// Ubicación: `apps/web/src/pages/index.astro`
//
// Descripción: Landing Page pública con secciones Hero, Features, CTA y formulario.
//            Usa LandingLayout sin sidebar ni auth.
//
// ADRs relacionados: 0022 (Frontend), 0029 (Landing + Leads), 0023 (i18n)

import LandingLayout from "../layouts/LandingLayout.astro";
import Hero from "../components/landing/Hero.astro";
import Features from "../components/landing/Features.astro";
import CallToAction from "../components/landing/CallToAction.astro";
import Footer from "../components/landing/Footer.astro";
import LeadForm from "../components/landing/LeadForm.svelte";
---

<LandingLayout
	title="Boilerplate — Fullstack Rust | Arquitectura Hexagonal"
	description="Boilerplate fullstack con Rust, Axum, Astro y Svelte. Arquitectura hexagonal, RBAC completo, PASETO Auth y deploy desde $5/mes."
>
	<main>
		<Hero />
		<Features />
		<section id="lead-form" class="py-20 bg-muted/30">
			<div class="container mx-auto px-4">
				<div class="flex flex-col items-center text-center max-w-2xl mx-auto mb-8">
					<h2 class="text-3xl lg:text-4xl font-bold mb-4">
						¿-listo para empezar?
					</h2>
					<p class="text-lg text-muted-foreground">
						Regístrate y te avisamos cuando lancemos.
					</p>
				</div>
				<LeadForm client:visible />
			</div>
		</section>
		<CallToAction />
	</main>
	<Footer />
</LandingLayout>