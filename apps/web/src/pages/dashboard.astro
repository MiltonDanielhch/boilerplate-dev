---
// Ubicación: `apps/web/src/pages/dashboard.astro`
//
// Descripción: Página del dashboard con métricas en tiempo real usando
//              TanStack Query para obtener datos del backend API.
//              Muestra usuarios totales, health de API y sesiones activas.
//
// ADRs relacionados: 0022 (Frontend), 0021 (OpenAPI)

import DashboardLayout from "../layouts/DashboardLayout.astro";
import StatsOverview from "../components/dashboard/StatsOverview.svelte";
import * as Card from "$lib/components/ui/card/index.js";
---

<DashboardLayout title="Dashboard">
	<StatsOverview client:only="svelte" />

	<div class="mt-6">
		<Card.Root>
			<Card.Header>
				<Card.Title>Welcome to Boilerplate</Card.Title>
				<Card.Description>
					Dashboard conectado a API Rust. Los datos de usuarios se obtienen
					en tiempo real desde el backend.
				</Card.Description>
			</Card.Header>
		</Card.Root>
	</div>
</DashboardLayout>
