---
// Ubicación: `apps/web/src/pages/dashboard.astro`
//
// Descripción: Página del dashboard con métricas de ejemplo usando
//              componentes shadcn-svelte (Card, Badge).
//              Datos estáticos de demostración - conectar con API en FE.IV.
//
// ADRs relacionados: 0022 (Frontend), 0021 (OpenAPI)

import DashboardLayout from "../layouts/DashboardLayout.astro";
import * as Card from "$lib/components/ui/card/index.js";
import Badge from "$lib/components/ui/badge/badge.svelte";
---

<DashboardLayout title="Dashboard">
	<div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
		<Card.Root>
			<Card.Header class="flex flex-row items-center justify-between space-y-0 pb-2">
				<Card.Title class="text-sm font-medium">Total Users</Card.Title>
				<Badge variant="secondary">Live</Badge>
			</Card.Header>
			<Card.Content>
				<div class="text-2xl font-bold">1,234</div>
				<p class="text-xs text-muted-foreground">+12% from last month</p>
			</Card.Content>
		</Card.Root>
		
		<Card.Root>
			<Card.Header class="flex flex-row items-center justify-between space-y-0 pb-2">
				<Card.Title class="text-sm font-medium">Active Sessions</Card.Title>
			</Card.Header>
			<Card.Content>
				<div class="text-2xl font-bold">42</div>
				<p class="text-xs text-muted-foreground">Current active users</p>
			</Card.Content>
		</Card.Root>
		
		<Card.Root>
			<Card.Header class="flex flex-row items-center justify-between space-y-0 pb-2">
				<Card.Title class="text-sm font-medium">API Health</Card.Title>
				<Badge variant="default">OK</Badge>
			</Card.Header>
			<Card.Content>
				<div class="text-2xl font-bold">99.9%</div>
				<p class="text-xs text-muted-foreground">Uptime last 30 days</p>
			</Card.Content>
		</Card.Root>
		
		<Card.Root>
			<Card.Header class="flex flex-row items-center justify-between space-y-0 pb-2">
				<Card.Title class="text-sm font-medium">Database</Card.Title>
				<Badge variant="outline">SQLite</Badge>
			</Card.Header>
			<Card.Content>
				<div class="text-2xl font-bold">12ms</div>
				<p class="text-xs text-muted-foreground">Avg response time</p>
			</Card.Content>
		</Card.Root>
	</div>
	
	<div class="mt-6">
		<Card.Root>
			<Card.Header>
				<Card.Title>Welcome to Boilerplate</Card.Title>
				<Card.Description>
					This dashboard uses Astro 6 SSR + Svelte 5 + shadcn-svelte components.
					Try clicking the toggle button in the sidebar to collapse/expand it.
				</Card.Description>
			</Card.Header>
		</Card.Root>
	</div>
</DashboardLayout>
