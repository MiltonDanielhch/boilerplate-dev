---
// Ubicación: `apps/web/src/pages/admin/content.astro`
// Descripción: Panel de gestión de contenido dinámico (CMS).
// ADR: 0023 (i18n)

import AdminLayout from "../../layouts/AdminLayout.astro";
import ContentManager from "../../components/admin/ContentManager.svelte";
import * as m from "$lib/paraglide/messages.js";
---

<AdminLayout title={m.sidebar_cms()}>
	<div class="space-y-6">
		<div>
			<h1 class="text-3xl font-extrabold tracking-tight text-white">{m.admin_cms_title()}</h1>
			<p class="text-slate-400 mt-2">
				{m.admin_cms_desc()}
			</p>
		</div>

		<ContentManager client:load />
	</div>
</AdminLayout>
