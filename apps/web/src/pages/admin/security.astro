---
// Ubicación: `apps/web/src/pages/admin/security.astro`
// Descripción: Panel de seguridad y gestión de sesiones.

import AdminLayout from "../../layouts/AdminLayout.astro";
import SessionManager from "../../components/admin/SessionManager.svelte";
---

<AdminLayout title="System Security">
	<div class="space-y-6">
		<div>
			<h1 class="text-3xl font-extrabold tracking-tight text-white">System Security</h1>
			<p class="text-slate-400 mt-2">
				Monitor active sessions, revoke access, and review security health.
			</p>
		</div>

		<SessionManager client:load />
	</div>
</AdminLayout>
