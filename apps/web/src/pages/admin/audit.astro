---
// Ubicación: `apps/web/src/pages/admin/audit.astro`
// Descripción: Registro de auditoría de seguridad.

import AdminLayout from "../../layouts/AdminLayout.astro";
import AuditLogTable from "../../components/admin/AuditLogTable.svelte";
import * as m from "$lib/paraglide/messages.js";
---

<AdminLayout title={m.security_audit_title()}>
	<div class="space-y-6">
		<div>
			<h1 class="text-3xl font-extrabold tracking-tight text-white">{m.security_audit_title()}</h1>
			<p class="text-slate-400 mt-2">
				{m.security_audit_desc()}
			</p>
		</div>

		<AuditLogTable client:load />
	</div>
</AdminLayout>
