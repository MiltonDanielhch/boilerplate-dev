---
// Ubicación: `apps/web/src/components/landing/Hero.astro`
//
// Descripción: Sección Hero de la landing page.
//            Propuesta de valor principal con CTA al formulario.
//
// ADRs relacionados: 0022 (Frontend)

import Button from "$lib/components/ui/button/button.svelte";
---

<section class="relative overflow-hidden py-20 lg:py-32">
	<div class="container mx-auto px-4">
		<div class="flex flex-col items-center text-center max-w-3xl mx-auto">
			<h1 class="text-4xl lg:text-6xl font-bold tracking-tight mb-6">
				<span class="bg-gradient-to-r from-primary to-primary/60 bg-clip-text text-transparent">
					Boilerplate Fullstack
				</span>
			</h1>
			
			<p class="text-xl lg:text-2xl text-muted-foreground mb-8 max-w-2xl">
				Construye aplicaciones web escalables con arquitectura hexagonal en Rust.
				RBAC completo, PASETO Auth y deploy desde $5/mes.
			</p>
			
			<div class="flex flex-col sm:flex-row gap-4">
				<Button href="#lead-form" size="lg" class="w-full sm:w-auto">
					Notificarme del lanzamiento
				</Button>
				<Button href="http://localhost:3000/docs" target="_blank" variant="outline" size="lg" class="w-full sm:w-auto">
					Ver documentación
				</Button>
			</div>
			
			<p class="text-sm text-muted-foreground mt-4">
				✨ Open source • Rust + Astro + Svelte 5
			</p>
		</div>
	</div>
</section>