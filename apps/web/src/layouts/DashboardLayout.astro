---
// Ubicación: `apps/web/src/layouts/DashboardLayout.astro`
//
// Descripción: Layout para páginas del dashboard con sidebar colapsable,
//              topbar fijo y área de contenido principal.
//              TODO: Implementar verificación PASETO en SSR (ADR 0008).
//
// ADRs relacionados: 0022 (Frontend), 0008 (PASETO), 0006 (RBAC)

import BaseLayout from "./BaseLayout.astro";
import Sidebar from "../components/layout/Sidebar.svelte";

interface Props {
	title?: string;
	description?: string;
}

const { title, description } = Astro.props;

// TODO: Implementar verificación PASETO en SSR
// const token = Astro.cookies.get("access_token");
// if (!token) {
//   return Astro.redirect("/login");
// }
---

<BaseLayout title={title} description={description}>
	<div class="flex min-h-screen">
		<Sidebar client:load />
		<main id="main-content" class="flex-1 transition-all duration-300" style="margin-left: 16rem;">
			<!-- Topbar -->
			<header class="sticky top-0 z-30 h-16 border-b bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
				<div class="flex h-full items-center justify-between px-6">
					<h1 class="text-xl font-semibold">{title}</h1>
					<div class="flex items-center gap-4">
						<!-- TODO: User menu, notifications -->
					</div>
				</div>
			</header>
			
			<!-- Canvas central -->
			<div class="p-6">
				<slot />
			</div>
		</main>
	</div>
	<script>
		// Listen for sidebar toggle events to adjust main content
		document.addEventListener('sidebar-toggle', (e: CustomEvent) => {
			const main = document.getElementById('main-content');
			if (main) {
				main.style.marginLeft = e.detail.collapsed ? '4rem' : '16rem';
			}
		});
	</script>
</BaseLayout>
