---
// Ubicación: `apps/web/src/layouts/DashboardLayout.astro`
//
// Descripción: Layout para páginas del dashboard con sidebar colapsable,
//              navegación responsive, topbar y command palette.
//              Integra RBAC en toda la UI.
//
// ADRs relacionados: 0022 (Frontend), 0006 (RBAC UI)

import BaseLayout from "./BaseLayout.astro";
import Sidebar from "../components/layout/Sidebar.svelte";
import Topbar from "../components/layout/Topbar.svelte";
import CommandPalette from "../components/layout/CommandPalette.svelte";
import AuthInit from "../components/auth/AuthInit.svelte";

interface Props {
	title?: string;
	description?: string;
}

const { title, description } = Astro.props;

// TODO: Implementar verificación PASETO en SSR
// const token = Astro.cookies.get("access_token");
// if (!token) {
//   return Astro.redirect("/login");
// }
---

<BaseLayout title={title} description={description}>
	<div class="flex min-h-screen">
		<AuthInit client:load />
		<Sidebar client:load />
		<main id="main-content" class="flex-1 transition-all duration-300 lg:ml-64">
			<!-- Topbar con CommandPalette integrado -->
			<Topbar client:load />

			<!-- Canvas central -->
			<div class="p-6">
				<slot />
			</div>
		</main>
	</div>
	<CommandPalette client:load />
	<script>
		// Listen for sidebar toggle events to adjust main content
		document.addEventListener('sidebar-toggle', (e: any) => {
			const main = document.getElementById('main-content');
			if (main) {
				if (window.innerWidth >= 1024) { // Solo en desktop (lg)
					main.classList.toggle('lg:ml-64', !e.detail.collapsed);
					main.classList.toggle('lg:ml-16', e.detail.collapsed);
				}
			}
		});
	</script>
</BaseLayout>
