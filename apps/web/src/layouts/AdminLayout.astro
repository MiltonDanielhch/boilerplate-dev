---
// Ubicación: `apps/web/src/layouts/AdminLayout.astro`
//
// Descripción: Layout dedicado para el panel de administración.
//              Forza el modo oscuro (ADR 0022) y protege las rutas en SSR.
//
// ADRs relacionados: 0022 (Frontend), 0006 (RBAC UI)

import BaseLayout from "./BaseLayout.astro";
import Sidebar from "../components/layout/Sidebar.svelte";
import Topbar from "../components/layout/Topbar.svelte";
import AuthInit from "../components/auth/AuthInit.svelte";

interface Props {
	title?: string;
	description?: string;
}

const { title, description } = Astro.props;

// TODO: Implementar verificación de ROL ADMIN en SSR
// const token = Astro.cookies.get("access_token")?.value;
// if (!token) return Astro.redirect("/login");
---

<BaseLayout title={title} description={description}>
	<AuthInit client:only="svelte" />
	<div class="flex min-h-screen bg-slate-950 text-slate-50">
		<!-- Sidebar específico de admin o compartido con filtros RBAC -->
		<Sidebar client:load />
		
		<main id="admin-content" class="flex-1 transition-all duration-300 lg:ml-64">
			<Topbar client:load />

			<div class="p-6 lg:p-8 max-w-7xl mx-auto">
				<slot />
			</div>
		</main>
	</div>

	<script>
		// Forzar modo oscuro para el área de admin
		document.documentElement.classList.add('dark');
		
		document.addEventListener('sidebar-toggle', (e: any) => {
			const main = document.getElementById('admin-content');
			if (main) {
				if (window.innerWidth >= 1024) {
					main.classList.toggle('lg:ml-64', !e.detail.collapsed);
					main.classList.toggle('lg:ml-16', e.detail.collapsed);
				}
			}
		});
	</script>
</BaseLayout>
