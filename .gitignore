# Ubicación: `.gitignore`
#
# Descripción: Archivos y directorios ignorados por Git.
#              Incluye Rust, Node, SQLite, variables de entorno.
#
# ADRs relacionados: ADR 0012 (Herramientas), ADR 0002 (Configuración - Secretos)

# =============================================================================
# RUST
# =============================================================================
/target
**/*.rs.bk
*.rlib
*.dll
*.so
*.dylib

# Cargo.lock se INCLUYE en git — este es un binario, no una librería
# (NO añadir Cargo.lock al .gitignore)

# =============================================================================
# VARIABLES DE ENTORNO — NUNCA en git
# =============================================================================
.env.local
# .env
.env.*.local
.env.production
.env.staging

# =============================================================================
# DATOS LOCALES
# =============================================================================
# Database files (runtime)
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Data directory except migrations and seeds
/data/*
!/data/migrations/
!/data/migrations/*.sql
!/data/seeds/
!/data/seeds/*.sql

# =============================================================================
# NODE / PNPM
# =============================================================================
node_modules
.pnpm-store
.pnpm-debug.log*

# =============================================================================
# FRONTEND (Astro)
# =============================================================================
apps/web/.astro
apps/web/dist
apps/mailer/dist
apps/web/node_modules
apps/mailer/node_modules

# =============================================================================
# IDE / EDITORES
# =============================================================================
.idea
.vscode
*.swp
*.swo
*~
.DS_Store

# =============================================================================
# LOGS
# =============================================================================
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =============================================================================
# COBERTURA DE TESTS
# =============================================================================
*.profraw
*.profdata
coverage/
tarpaulin-report.html

# =============================================================================
# TEMPORALES
# =============================================================================
tmp/
temp/
*.tmp
