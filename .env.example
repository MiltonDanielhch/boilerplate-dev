# =============================================================================
# Boilerplate - Variables de Entorno
# =============================================================================
# Copiar a .env.local y configurar valores reales
# Ref: ADR 0002 (Config), ADR 0008 (PASETO), ADR 0004 (Litestream)
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Servidor
# ─────────────────────────────────────────────────────────────────────────────
SERVER_PORT=3000
ENVIRONMENT=development
RUST_LOG=info

# ─────────────────────────────────────────────────────────────────────────────
# Base de Datos
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:data/database.sqlite3

# ─────────────────────────────────────────────────────────────────────────────
# Seguridad - PASETO v4 (NO JWT)
# Generar con: openssl rand -hex 32
# Ref: ADR 0008
# ─────────────────────────────────────────────────────────────────────────────
PASETO_SECRET=cambia_esto_por_un_secreto_de_32_bytes_hex

# ─────────────────────────────────────────────────────────────────────────────
# Email - Resend
# Ref: ADR 0019
# ─────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM=noreply@example.com

# ─────────────────────────────────────────────────────────────────────────────
# Almacenamiento - S3/Tigris
# Ref: ADR 0020
# ─────────────────────────────────────────────────────────────────────────────
AWS_ENDPOINT_URL_S3=https://fly.storage.tigris.dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
STORAGE_BUCKET=boilerplate-storage

# ─────────────────────────────────────────────────────────────────────────────
# Backup - Litestream
# Ref: ADR 0004
# ─────────────────────────────────────────────────────────────────────────────
LITESTREAM_BUCKET=s3://boilerplate-backups/litestream

# ─────────────────────────────────────────────────────────────────────────────
# Monitoreo - Sentry (opcional)
# Ref: ADR 0016
# ─────────────────────────────────────────────────────────────────────────────
SENTRY_DSN=
OTLP_ENDPOINT=

# ─────────────────────────────────────────────────────────────────────────────
# Healthchecks (opcional)
# Ref: ADR 0015
# ─────────────────────────────────────────────────────────────────────────────
HC_LITESTREAM_UUID=
HC_DEPLOY_UUID=
